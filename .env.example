# Web3Forms access key for the contact form (https://web3forms.com).
# Create a free key by entering your email at https://web3forms.com — submissions
# get emailed to that address. This key is exposed in the client, which is expected.
PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key

# Cloudflare Turnstile SITE key (public) for contact-form spam protection.
# Get it from the Cloudflare dashboard. Add the matching SECRET key in your
# Web3Forms dashboard (server-side) — never put the secret key here.
# Leave blank to disable Turnstile and fall back to the honeypot only.
PUBLIC_TURNSTILE_SITE_KEY=
