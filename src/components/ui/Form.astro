---
import type { Form as Props } from '~/types';
import Button from '~/components/ui/Button.astro';

const {
  inputs,
  textarea,
  disclaimer,
  button = 'Contact us',
  description = '',
  action,
  accessKey,
  turnstileSiteKey,
} = Astro.props;
---

<form data-contact-form={action ? '' : undefined} action={action} method="POST">
  {action && accessKey && <input type="hidden" name="access_key" value={accessKey} />}
  {/* Honeypot field — bots fill this, humans never see it */}
  {
    action && (
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />
    )
  }
  {
    inputs &&
      inputs.map(
        ({ type = 'text', name, label = '', autocomplete = 'on', placeholder = '' }) =>
          name && (
            <div class="mb-6">
              {label && (
                <label for={name} class="block text-sm font-medium">
                  {label}
                </label>
              )}
              <input
                type={type}
                name={name}
                id={name}
                autocomplete={autocomplete}
                placeholder={placeholder}
                class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
              />
            </div>
          )
      )
  }

  {
    textarea && (
      <div>
        <label for="textarea" class="block text-sm font-medium">
          {textarea.label}
        </label>
        <textarea
          id="textarea"
          name={textarea.name ? textarea.name : 'message'}
          rows={textarea.rows ? textarea.rows : 4}
          placeholder={textarea.placeholder}
          class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
        />
      </div>
    )
  }

  {
    disclaimer && (
      <div class="mt-3 flex items-start">
        <div class="flex mt-0.5">
          <input
            id="disclaimer"
            name="disclaimer"
            type="checkbox"
            class="cursor-pointer mt-1 py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
          />
        </div>
        <div class="ml-3">
          <label for="disclaimer" class="cursor-pointer select-none text-sm text-gray-600 dark:text-gray-400">
            {disclaimer.label}
          </label>
        </div>
      </div>
    )
  }

  {turnstileSiteKey && <div class="cf-turnstile mt-6 flex justify-center" data-sitekey={turnstileSiteKey} />}

  {
    button && (
      <div class="mt-10 grid">
        <Button variant="primary" type="submit">
          {button}
        </Button>
      </div>
    )
  }

  {action && <p data-form-result class="mt-4 text-center text-sm hidden" role="status" aria-live="polite" />}

  {
    description && (
      <div class="mt-3 text-center">
        <p class="text-sm text-gray-600 dark:text-gray-400">{description}</p>
      </div>
    )
  }
</form>

<script>
  document.querySelectorAll('form[data-contact-form]').forEach((el) => {
    const form = el as HTMLFormElement;
    const result = form.querySelector('[data-form-result]') as HTMLElement | null;
    const submit = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    const setResult = (message: string, ok: boolean) => {
      if (!result) return;
      result.textContent = message;
      result.classList.remove('hidden', 'text-green-600', 'text-red-600');
      result.classList.add(ok ? 'text-green-600' : 'text-red-600');
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (submit) submit.disabled = true;
      setResult('Sending…', true);

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const data = await response.json().catch(() => ({}));

        if (response.ok) {
          form.reset();
          setResult(data.message || 'Thanks! Your message has been sent.', true);
        } else {
          setResult(data.message || 'Something went wrong. Please try again.', false);
        }
      } catch {
        setResult('Network error. Please try again.', false);
      } finally {
        if (submit) submit.disabled = false;
        // Turnstile tokens are single-use — reset the widget for another submission
        (window as Window & { turnstile?: { reset: () => void } }).turnstile?.reset();
      }
    });
  });
</script>

{turnstileSiteKey && <script is:inline async defer src="https://challenges.cloudflare.com/turnstile/v0/api.js" />}
